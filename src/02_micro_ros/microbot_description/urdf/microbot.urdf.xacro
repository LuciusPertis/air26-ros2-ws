<?xml version="1.0"?>
<!-- AIR26 Workshop 02 (micro_ros) — the obstacle-avoider bot.
     A small skid-steer rover: cuboid chassis (almost square), 4 driven wheels,
     3 ultrasonic range sensors (front/left/right), and labelled motor / MCU /
     battery cuboids so kids can point at "the parts". One model for RViz, Gazebo
     and MuJoCo. Set use_gazebo:=true to add the Ignition DiffDrive + lidar tags. -->
<robot name="microbot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="use_gazebo" default="false"/>

  <!-- dimensions -->
  <xacro:property name="body_x" value="0.30"/>
  <xacro:property name="body_y" value="0.28"/>
  <xacro:property name="body_z" value="0.10"/>
  <xacro:property name="wheel_r" value="0.05"/>
  <xacro:property name="wheel_w" value="0.04"/>
  <xacro:property name="wheel_dx" value="0.11"/>   <!-- wheel x offset -->
  <xacro:property name="wheel_dy" value="0.16"/>   <!-- wheel y offset (outside body) -->

  <!-- materials -->
  <material name="charcoal"><color rgba="0.25 0.25 0.28 1"/></material>
  <material name="black">   <color rgba="0.05 0.05 0.05 1"/></material>
  <material name="us_blue">  <color rgba="0.1 0.4 0.95 1"/></material>
  <material name="bat_green"><color rgba="0.1 0.7 0.25 1"/></material>
  <material name="mcu_red">  <color rgba="0.85 0.1 0.1 1"/></material>
  <material name="mot_orange"><color rgba="0.95 0.55 0.1 1"/></material>

  <xacro:macro name="box_inertial" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${mass*(y*y+z*z)/12.0}" iyy="${mass*(x*x+z*z)/12.0}"
               izz="${mass*(x*x+y*y)/12.0}" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- labelled cuboid component (battery / mcu / motor) -->
  <xacro:macro name="part" params="name x y z px py pz material">
    <link name="${name}">
      <visual>
        <geometry><box size="${x} ${y} ${z}"/></geometry>
        <material name="${material}"/>
      </visual>
      <xacro:box_inertial mass="0.1" x="${x}" y="${y}" z="${z}"/>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${px} ${py} ${pz}"/>
    </joint>
  </xacro:macro>

  <!-- driven wheel -->
  <xacro:macro name="wheel" params="name px py">
    <link name="${name}">
      <visual>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin rpy="1.5708 0 0"/>
        <geometry><cylinder radius="${wheel_r}" length="${wheel_w}"/></geometry>
      </collision>
      <xacro:box_inertial mass="0.2" x="${wheel_r}" y="${wheel_w}" z="${wheel_r}"/>
    </link>
    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${px} ${py} ${-body_z/2}"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ultrasonic sensor (small box + an outward-pointing frame named <name>_frame) -->
  <xacro:macro name="ultrasonic" params="name px py pz yaw">
    <link name="${name}">
      <visual>
        <geometry><box size="0.02 0.05 0.03"/></geometry>
        <material name="us_blue"/>
      </visual>
      <xacro:box_inertial mass="0.02" x="0.02" y="0.05" z="0.03"/>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${px} ${py} ${pz}" rpy="0 0 ${yaw}"/>
    </joint>
  </xacro:macro>

  <!-- ===================== chassis ===================== -->
  <link name="base_link">
    <visual>
      <geometry><box size="${body_x} ${body_y} ${body_z}"/></geometry>
      <material name="charcoal"/>
    </visual>
    <collision>
      <geometry><box size="${body_x} ${body_y} ${body_z}"/></geometry>
    </collision>
    <xacro:box_inertial mass="2.0" x="${body_x}" y="${body_y}" z="${body_z}"/>
  </link>

  <!-- ===================== wheels (all driven) ===================== -->
  <xacro:wheel name="wheel_fl" px="${ wheel_dx}" py="${ wheel_dy}"/>
  <xacro:wheel name="wheel_fr" px="${ wheel_dx}" py="${-wheel_dy}"/>
  <xacro:wheel name="wheel_rl" px="${-wheel_dx}" py="${ wheel_dy}"/>
  <xacro:wheel name="wheel_rr" px="${-wheel_dx}" py="${-wheel_dy}"/>

  <!-- ===================== ultrasonics ===================== -->
  <xacro:ultrasonic name="us_front" px="${ body_x/2}" py="0"            pz="0" yaw="0"/>
  <xacro:ultrasonic name="us_left"  px="0"            py="${ body_y/2}" pz="0" yaw="1.5708"/>
  <xacro:ultrasonic name="us_right" px="0"            py="${-body_y/2}" pz="0" yaw="-1.5708"/>

  <!-- ===================== labelled components ===================== -->
  <xacro:part name="battery" x="0.10" y="0.12" z="0.04" px="-0.05" py="0"     pz="${body_z/2+0.02}" material="bat_green"/>
  <xacro:part name="mcu"     x="0.06" y="0.06" z="0.02" px="0.06"  py="0.05"  pz="${body_z/2+0.01}" material="mcu_red"/>
  <xacro:part name="motor"   x="0.05" y="0.05" z="0.04" px="0.08"  py="-0.06" pz="${body_z/2+0.02}" material="mot_orange"/>

  <xacro:if value="$(arg use_gazebo)">
    <xacro:include filename="$(find microbot_description)/urdf/microbot.gazebo.xacro"/>
  </xacro:if>

</robot>
