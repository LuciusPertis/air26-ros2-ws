<?xml version="1.0" ?>
<!-- AIR26 Workshop 05 — Gazebo (Harmonic) world for the perception rover.
     Reference embodiment (Webots is primary). Skid-steer rover via the DiffDrive system
     (2 joints per side), 3 single-beam gpu_lidars = the ultrasonics (bridged LaserScan ->
     scan_to_range -> /ultrasonic/*), and a front camera. Arena targets: a bright panel
     (light-seek B4) and a green box (colour-seek B5). ArUco (B6) is a Webots/real-cam
     feature — see THEORY.md / the MuJoCo note. -->
<sdf version="1.8">
  <world name="perceptbot">

    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system"
            name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system"
            name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.3 0.2 -1</direction>
    </light>

    <!-- ground -->
    <model name="ground"><static>true</static><link name="l">
      <collision name="c"><geometry><plane><normal>0 0 1</normal><size>8 8</size></plane></geometry></collision>
      <visual name="v"><geometry><plane><normal>0 0 1</normal><size>8 8</size></plane></geometry>
        <material><ambient>0.3 0.3 0.35 1</ambient><diffuse>0.3 0.3 0.35 1</diffuse></material></visual>
    </link></model>

    <!-- arena walls (4 static boxes) -->
    <model name="walls"><static>true</static><link name="l">
      <collision name="n"><pose>0 2 0.15 0 0 0</pose><geometry><box><size>4 0.1 0.3</size></box></geometry></collision>
      <visual    name="nv"><pose>0 2 0.15 0 0 0</pose><geometry><box><size>4 0.1 0.3</size></box></geometry><material><diffuse>0.5 0.4 0.3 1</diffuse></material></visual>
      <collision name="s"><pose>0 -2 0.15 0 0 0</pose><geometry><box><size>4 0.1 0.3</size></box></geometry></collision>
      <visual    name="sv"><pose>0 -2 0.15 0 0 0</pose><geometry><box><size>4 0.1 0.3</size></box></geometry><material><diffuse>0.5 0.4 0.3 1</diffuse></material></visual>
      <collision name="e"><pose>2 0 0.15 0 0 0</pose><geometry><box><size>0.1 4 0.3</size></box></geometry></collision>
      <visual    name="ev"><pose>2 0 0.15 0 0 0</pose><geometry><box><size>0.1 4 0.3</size></box></geometry><material><diffuse>0.5 0.4 0.3 1</diffuse></material></visual>
      <collision name="w"><pose>-2 0 0.15 0 0 0</pose><geometry><box><size>0.1 4 0.3</size></box></geometry></collision>
      <visual    name="wv"><pose>-2 0 0.15 0 0 0</pose><geometry><box><size>0.1 4 0.3</size></box></geometry><material><diffuse>0.5 0.4 0.3 1</diffuse></material></visual>
    </link></model>

    <!-- B4 light-seek: bright emissive white panel + a spotlight on +Y wall -->
    <model name="light_panel"><static>true</static><link name="l">
      <pose>0 1.9 0.4 0 0 0</pose>
      <visual name="v"><geometry><box><size>0.8 0.05 0.6</size></box></geometry>
        <material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse><emissive>1 1 1 1</emissive></material></visual>
    </link></model>
    <light type="spot" name="panel_light">
      <pose>0 1.5 0.8 0 0 0</pose><diffuse>1 1 1 1</diffuse><specular>0.3 0.3 0.3 1</specular>
      <direction>0 -0.4 -0.3</direction><attenuation><range>10</range><linear>0.05</linear></attenuation>
      <spot><inner_angle>0.6</inner_angle><outer_angle>1.0</outer_angle><falloff>1</falloff></spot>
    </light>

    <!-- B5 colour-seek: green box on -Y wall -->
    <model name="green_box"><static>true</static><link name="l">
      <pose>0 -1.7 0.15 0 0 0</pose>
      <collision name="c"><geometry><box><size>0.3 0.3 0.3</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.3 0.3 0.3</size></box></geometry>
        <material><ambient>0.1 0.8 0.2 1</ambient><diffuse>0.1 0.8 0.2 1</diffuse></material></visual>
    </link></model>

    <!-- pillars for obstacle behaviours 1-3 -->
    <model name="pillar_a"><static>true</static><link name="l"><pose>-1.0 0.6 0.2 0 0 0</pose>
      <collision name="c"><geometry><cylinder><radius>0.1</radius><length>0.4</length></cylinder></geometry></collision>
      <visual name="v"><geometry><cylinder><radius>0.1</radius><length>0.4</length></cylinder></geometry><material><diffuse>0.6 0.4 0.2 1</diffuse></material></visual>
    </link></model>
    <model name="pillar_b"><static>true</static><link name="l"><pose>-1.2 -0.8 0.2 0 0 0</pose>
      <collision name="c"><geometry><cylinder><radius>0.1</radius><length>0.4</length></cylinder></geometry></collision>
      <visual name="v"><geometry><cylinder><radius>0.1</radius><length>0.4</length></cylinder></geometry><material><diffuse>0.6 0.4 0.2 1</diffuse></material></visual>
    </link></model>

    <!-- ============================ the rover ============================ -->
    <model name="perceptbot">
      <pose>0 0 0.06 0 0 0</pose>

      <link name="base_link">
        <inertial><mass>2.0</mass><inertia><ixx>0.02</ixx><iyy>0.02</iyy><izz>0.03</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
        <collision name="c"><geometry><box><size>0.30 0.28 0.10</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.30 0.28 0.10</size></box></geometry>
          <material><diffuse>0.25 0.25 0.28 1</diffuse></material></visual>

        <!-- 3 single-beam gpu_lidars = ultrasonics -->
        <sensor name="us_front" type="gpu_lidar">
          <pose>0.15 0 0 0 0 0</pose><topic>scan_front</topic><update_rate>10</update_rate>
          <lidar><scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal></scan>
            <range><min>0.04</min><max>2.0</max></range></lidar>
        </sensor>
        <sensor name="us_left" type="gpu_lidar">
          <pose>0 0.14 0 0 0 1.5708</pose><topic>scan_left</topic><update_rate>10</update_rate>
          <lidar><scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal></scan>
            <range><min>0.04</min><max>2.0</max></range></lidar>
        </sensor>
        <sensor name="us_right" type="gpu_lidar">
          <pose>0 -0.14 0 0 0 -1.5708</pose><topic>scan_right</topic><update_rate>10</update_rate>
          <lidar><scan><horizontal><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></horizontal></scan>
            <range><min>0.04</min><max>2.0</max></range></lidar>
        </sensor>

        <!-- front camera -->
        <sensor name="camera" type="camera">
          <pose>0.15 0 0.04 0 0 0</pose><topic>camera</topic><update_rate>20</update_rate>
          <camera><horizontal_fov>1.0</horizontal_fov>
            <image><width>320</width><height>240</height><format>R8G8B8</format></image>
            <clip><near>0.05</near><far>20</far></clip></camera>
        </sensor>
      </link>

      <!-- 4 wheels -->
      <link name="wheel_fl"><pose>0.11 0.16 -0.05 -1.5708 0 0</pose>
        <inertial><mass>0.2</mass><inertia><ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
        <collision name="c"><geometry><cylinder><radius>0.05</radius><length>0.04</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.05</radius><length>0.04</length></cylinder></geometry><material><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      </link>
      <link name="wheel_fr"><pose>0.11 -0.16 -0.05 -1.5708 0 0</pose>
        <inertial><mass>0.2</mass><inertia><ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
        <collision name="c"><geometry><cylinder><radius>0.05</radius><length>0.04</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.05</radius><length>0.04</length></cylinder></geometry><material><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      </link>
      <link name="wheel_rl"><pose>-0.11 0.16 -0.05 -1.5708 0 0</pose>
        <inertial><mass>0.2</mass><inertia><ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
        <collision name="c"><geometry><cylinder><radius>0.05</radius><length>0.04</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.05</radius><length>0.04</length></cylinder></geometry><material><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      </link>
      <link name="wheel_rr"><pose>-0.11 -0.16 -0.05 -1.5708 0 0</pose>
        <inertial><mass>0.2</mass><inertia><ixx>0.0003</ixx><iyy>0.0003</iyy><izz>0.0005</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
        <collision name="c"><geometry><cylinder><radius>0.05</radius><length>0.04</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.05</radius><length>0.04</length></cylinder></geometry><material><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      </link>

      <joint name="wheel_fl_joint" type="revolute"><parent>base_link</parent><child>wheel_fl</child><axis><xyz>0 1 0</xyz></axis></joint>
      <joint name="wheel_fr_joint" type="revolute"><parent>base_link</parent><child>wheel_fr</child><axis><xyz>0 1 0</xyz></axis></joint>
      <joint name="wheel_rl_joint" type="revolute"><parent>base_link</parent><child>wheel_rl</child><axis><xyz>0 1 0</xyz></axis></joint>
      <joint name="wheel_rr_joint" type="revolute"><parent>base_link</parent><child>wheel_rr</child><axis><xyz>0 1 0</xyz></axis></joint>

      <!-- skid-steer: 2 joints per side -->
      <plugin filename="gz-sim-diff-drive-system"
              name="gz::sim::systems::DiffDrive">
        <left_joint>wheel_fl_joint</left_joint>
        <left_joint>wheel_rl_joint</left_joint>
        <right_joint>wheel_fr_joint</right_joint>
        <right_joint>wheel_rr_joint</right_joint>
        <wheel_separation>0.32</wheel_separation>
        <wheel_radius>0.05</wheel_radius>
        <topic>cmd_vel</topic>
        <odom_topic>odom</odom_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
      </plugin>
    </model>

  </world>
</sdf>
