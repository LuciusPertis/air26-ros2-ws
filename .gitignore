# --- colcon workspace build artifacts (regenerated by `colcon build`) ---
/build/
/install/
/log/

# --- PlatformIO firmware build caches (regenerated by `pio run`; ~1 GB) ---
**/.pio/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# --- editor / OS cruft ---
*.swp
*~
.DS_Store
.vscode/
.idea/

# --- Claude Code local settings (keep project settings.json if you add one) ---
.claude/settings.local.json
.claude/worktrees/

# --- misc local files ---
*.log
